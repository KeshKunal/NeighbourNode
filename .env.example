# NeighbourNode Environment Variables
# Copy to .env and fill in real values

# ─── Supabase ────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ─── Telegram ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ─── Google Calendar ─────────────────────────────────────────────
GOOGLE_CALENDAR_ID=
GOOGLE_CREDENTIALS_JSON=
GOOGLE_CREDENTIALS_PATH=

# ─── AI Models ───────────────────────────────────────────────────
GEMINI_FLASH_MODEL=gemini-1.5-flash-latest
GEMINI_PRO_MODEL=gemini-1.5-pro-latest

# ─── Feature Flags ───────────────────────────────────────────────
# Set to true to skip real Telegram/Calendar calls during local dev
MOCK_EXTERNAL_SERVICES=true
